        const themas = [...new Set(videos.map(v => v.thema))];
        let actiefThema = themas[0];
        function init() {
            const tabsEl = document.getElementById('thema-tabs');
            themas.forEach(t => {
                const btn = document.createElement('button');
                btn.className = 'thema-tab' + (t === actiefThema ? ' actief' : '');
                btn.textContent = t.replace('Thema ', 'T').replace(' - ', ' ');
                btn.addEventListener('click', () => selecteerThema(t));
                tabsEl.appendChild(btn);
            });
            maakKnoppen();
        }
        function selecteerThema(thema) {
            actiefThema = thema;
            document.querySelectorAll('.thema-tab').forEach((b, i) => b.classList.toggle('actief', themas[i] === thema));
            maakKnoppen();
        }
        function maakKnoppen() {
            const lijst = document.getElementById('knoppen-sectie');
            lijst.innerHTML = '';
            videos.filter(v => v.thema === actiefThema).forEach(video => {
                const knop = document.createElement('button');
                knop.className = 'video-knop';
                const sterren = video.naam.includes('***') ? '***' : video.naam.includes('**') ? '**' : '*';
                const basis = video.naam.replace(/\*+/, '').trim();
                knop.innerHTML = '<span class="niveau-badge">' + sterren + '</span><span>' + basis + '</span>';
                knop.addEventListener('click', () => speelAf(video, knop));
                lijst.appendChild(knop);
            });
        }
        
        function speelAf(video, knop) {
            document.getElementById('welkom').style.display = 'none';
            document.getElementById('video-container').style.display = 'block';
            const src = 'https://www.youtube-nocookie.com/embed/' + video.id + '?autoplay=0&iv_load_policy=3&loop=0&modestbranding=1&rel=0';
            document.getElementById('youtube-iframe').src = src;
            document.getElementById('video-title').textContent = video.naam;
            document.querySelectorAll('.video-knop').forEach(b => b.classList.remove('actief'));
            if (knop) knop.classList.add('actief');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            document.getElementById('video-knoppen-balk').style.display = 'flex';
        }
        function verbergVideo() {
            document.getElementById('video-container').style.display = 'none';
            document.getElementById('welkom').style.display = 'block';
            document.getElementById('youtube-iframe').src = '';
            document.querySelectorAll('.video-knop').forEach(b => b.classList.remove('actief'));
        }
        function zetVolledigScherm() {
            const el = document.getElementById('video-wrapper');
            if (el.requestFullscreen) el.requestFullscreen();
            else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
            else if (el.mozRequestFullScreen) el.mozRequestFullScreen();
        }
        function sluitVolledigScherm() {
            if (document.exitFullscreen) document.exitFullscreen();
            else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
            else if (document.mozCancelFullScreen) document.mozCancelFullScreen();
        }
        function deelVideo() {
            const iframe = document.getElementById('youtube-iframe');
            const match = iframe.src.match(/embed\/([^?]+)/);
            if (!match) return;
            const link = window.location.origin + window.location.pathname + '?v=' + match[1];
            navigator.clipboard.writeText(link).then(() => {
                const knop = document.getElementById('deel-knop');
                knop.textContent = '✓ Gekopieerd!';
                setTimeout(() => knop.textContent = '🔗 Deel', 2000);
            });
        }

        
        const params = new URLSearchParams(window.location.search);
        const directId = params.get('v');
        if (directId) {
            document.getElementById('welkom').style.display = 'none';
            document.getElementById('nav-sectie').style.display = 'none';
            document.getElementById('deel-knop').style.display = 'none';
            document.getElementById('video-container').style.display = 'block';
            const video = videos.find(v => v.id === directId);
            const naam = video ? video.naam : directId;
            const src = 'https://www.youtube-nocookie.com/embed/' + directId + '?autoplay=0&iv_load_policy=3&loop=0&modestbranding=1&rel=0';
            document.getElementById('youtube-iframe').src = src;
            document.getElementById('video-title').textContent = naam;
        } else {
            document.getElementById('nav-sectie').style.display = 'block';
            init();
        }

